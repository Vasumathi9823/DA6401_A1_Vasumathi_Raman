import wandb
import numpy as np

def run_global_performance_sweep():
    learning_rates = [0.1, 0.01, 0.001]
    hidden_sizes_options = [[32, 32], [128, 128, 128], [512, 512, 512]] # Small vs Large models

    X_train, y_train_oh, X_val, y_val, X_test, y_test = load_and_prep_data('mnist')

    for lr in learning_rates:
        for hidden_sizes in hidden_sizes_options:
            run = wandb.init(
                project='DA6401_Assignment_1_ee21d063',
                name=f"sweep_lr{lr}_arch{len(hidden_sizes)}x{hidden_sizes[0]}",
                config={
                    "learning_rate": lr,
                    "hidden_layers": len(hidden_sizes),
                    "neurons_per_layer": hidden_sizes[0],
                    "optimizer": "rmsprop",
                    "activation": "relu",
                    "epochs": 10
                },
                reinit=True
            )

            model = NeuralNetwork(X_train.shape[1], hidden_sizes, 10, "relu", "xavier")
            opt = RMSProp(lr=lr)
            loss_fn = CrossEntropy()

            for epoch in range(10):
                logits = model.forward(X_train[:5000]) # Sample for speed
                loss_fn(logits, y_train_oh[:5000])
                model.backward(loss_fn.derivative())
                opt.update(model.layers)

                train_acc = accuracy_score(np.argmax(y_train_oh[:1000], axis=1),
                                         np.argmax(model.forward(X_train[:1000]), axis=1))
                test_acc = accuracy_score(y_test,
                                        np.argmax(model.forward(X_test), axis=1))

                wandb.log({
                    "epoch": epoch + 1,
                    "train_accuracy": train_acc,
                    "test_accuracy": test_acc,
                    "acc_gap": train_acc - test_acc
                })

            run.finish()

run_global_performance_sweep()
