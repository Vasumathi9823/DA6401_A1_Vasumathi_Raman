import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import confusion_matrix
import wandb
import numpy as np
import json

best_config = {
    "dataset": "mnist",
    "epochs": 10,             
    "batch_size": 128,        
    "learning_rate": 0.001,   
    "optimizer": "rmsprop",   
    "activation": "tanh",     
    "weight_init": "xavier",  
    "num_layers": 3,          
    "hidden_neurons": 128,   
    "weight_decay": 0.0      
}

def train_final_model(config):
    wandb.init(project='DA6401_Assignment_1_ee21d063', name='Best_Model_Final', config=config)

    # Load Data
    X_train, y_train_oh, X_val, y_val, X_test, y_test = load_and_prep_data(config['dataset'])

    # Build Network
    input_dim = X_train.shape[1]
    output_dim = 10
    hidden_sizes = [config['hidden_neurons']] * config['num_layers']
    model = NeuralNetwork(input_dim, hidden_sizes, output_dim, config['activation'], config['weight_init'])
    loss_fn = CrossEntropy()

    # Setup Optimizer
    if config['optimizer'] == 'nag':
        opt = NAG(lr=config['learning_rate'], weight_decay=config['weight_decay'])
    else:
        opt = SGD(lr=config['learning_rate'], weight_decay=config['weight_decay'])

    print(f"Training for {config['epochs']} epochs...")
    num_samples = X_train.shape[0]

    for epoch in range(config['epochs']):
        indices = np.random.permutation(num_samples)
        for i in range(0, num_samples, config['batch_size']):
            X_batch = X_train[indices[i:i+config['batch_size']]]
            y_batch = y_train_oh[indices[i:i+config['batch_size']]]

            logits = model.forward(X_batch)
            loss_fn(logits, y_batch)
            model.backward(loss_fn.derivative())
            opt.update(model.layers)

    test_logits = model.forward(X_test)
    test_preds = np.argmax(test_logits, axis=1)

    # 1. Confusion Matrix
    cm = confusion_matrix(y_test, test_preds)
    plt.figure(figsize=(10, 8))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues')
    plt.xlabel('Predicted')
    plt.ylabel('Actual')
    plt.title('Confusion Matrix')

    wandb.log({"confusion_matrix_plot": wandb.Image(plt)})
    plt.show()
    plt.close()

    error_idx = np.where(test_preds != y_test)[0]
    error_images = []
    for idx in error_idx[:10]:
        img = X_test[idx].reshape(28, 28)
        caption = f"True: {y_test[idx]}, Pred: {test_preds[idx]}"
        error_images.append(wandb.Image(img, caption=caption))

    wandb.log({"error_gallery": error_images})

    # Final Metrics
    final_test_acc = accuracy_score(y_test, test_preds)
    wandb.log({"final_test_accuracy": final_test_acc})
    wandb.finish()

    return model

final_model = train_final_model(best_config)
