        "epochs": 15,
        "batch_size": 128,
        "learning_rate": 0.001,
        "optimizer": "rmsprop",
        "activation": "relu",
        "weight_init": "xavier",
        "num_layers": 3,
        "hidden_neurons": 256, # Increased capacity
        "weight_decay": 0.0
    },
    # Config 3: 
    {
        "name": "Configuration 3",
        "dataset": "fashion_mnist",
